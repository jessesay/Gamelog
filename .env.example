# ================================================================
# PUBLIC — bundled into browser code. Never put private keys here.
# ================================================================

# Local: http://localhost:3000
# Production: https://your-domain.example (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Project Settings > Data API / API Keys.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# ================================================================
# PRIVATE — server/Vercel only. Never prefix these with NEXT_PUBLIC_.
# ================================================================

# Recommended Supabase elevated server key. It bypasses RLS.
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# Legacy alternative if the project does not have a new secret key yet.
# Set only one admin key unless you are rotating keys.
SUPABASE_SERVICE_ROLE_KEY=

# Optional server-side catalog providers.
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
RAWG_API_KEY=
ITCH_API_KEY=

# Optional multi-source import tuning (primarily for local/CI imports).
GAMELOG_IMPORT_SOURCES=rawg,steam,itch
RAWG_SYNC_PAGES=3
RAWG_PAGE_SIZE=40
STEAM_IMPORT_LIMIT=80
STEAM_APP_IDS=
ITCH_IMPORT_LIMIT=50
ITCH_GAME_URLS=

# Production allowlist for /catalog-builder/status (comma-separated).
# Local development can access the page without this setting.
CATALOG_ADMIN_EMAILS=

# Local AI Gateway auth only. Pull with `vercel env pull .env.local`.
# Do not manually create this variable in Vercel production.
VERCEL_OIDC_TOKEN=
