NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional: IGDB imports through server routes
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# Optional: RAWG trending import from browser
NEXT_PUBLIC_RAWG_API_KEY=

# AI Gateway local auth is pulled by Vercel CLI with: vercel env pull .env.local
# No AI Gateway API key is needed when VERCEL_OIDC_TOKEN is present.
VERCEL_OIDC_TOKEN=

# Server/admin only: required for the 10,000-game catalog importer.
# Never expose this key in browser code and never commit your real value.
SUPABASE_SERVICE_ROLE_KEY=
